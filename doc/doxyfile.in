PROJECT_NAME           = tapi
PROJECT_BRIEF          = "A modern testing framework in C17"
PROJECT_NUMBER         = @PROJECT_VERSION@

OUTPUT_DIRECTORY       = "build/doc/"
INPUT                  = "include/" \
                         "doc/" \
                         "src/"
EXCLUDE                = "src/int/" \
                         "src/entry.c"
FILE_PATTERNS          = *.c \
                         *.h \
                         *.md \
                         *.dox
RECURSIVE              = YES

EXTRACT_ALL            = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES
SEARCHENGINE           = YES

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

HTML_EXTRA_STYLESHEET  = @AWESOME_CSS_DIR@/doxygen-awesome.css
HTML_EXTRA_FILES       = @AWESOME_CSS_DIR@/doxygen-awesome-darkmode-toggle.js \
                         @AWESOME_CSS_DIR@/doxygen-awesome-fragment-copy-button.js \
                         @AWESOME_CSS_DIR@/doxygen-awesome-paragraph-link.js \
                         @AWESOME_CSS_DIR@/doxygen-awesome-interactive-toc.js

HTML_COLORSTYLE        = LIGHT
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
GENERATE_TREEVIEW      = NO

SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = NO
REFERENCES_RELATION    = NO